{
  "name": "reactcms-sdk",
  "version": "1.0.0",
  "description": "Lightweight JavaScript SDK for ReactCMS — auto-populate data-cms elements from your CMS",
  "main": "dist/sdk.js",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "files": ["dist/", "src/"],
  "scripts": {
    "build": "node scripts/bundle.js",
    "build:ts": "tsc --project tsconfig.build.json",
    "dev": "tsc --watch",
    "test:node": "node --experimental-vm-modules test/sdk.test.js",
    "lint": "eslint src --ext .ts"
  },
  "keywords": ["cms", "headless", "sdk", "content", "javascript"],
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.5.3"
  }
}
