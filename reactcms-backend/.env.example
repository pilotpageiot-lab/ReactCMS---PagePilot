# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3002
API_BASE_URL=http://localhost:3002

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://reactcms:secret@localhost:5432/reactcms_dev
DB_POOL_MIN=2
DB_POOL_MAX=10

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=CHANGE_ME_access_secret_minimum_32_chars
JWT_REFRESH_SECRET=CHANGE_ME_refresh_secret_minimum_32_chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Bcrypt ───────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173

# ─── Rate limits (requests per 60s) ──────────────────────────────────────────
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_API_MAX=120
RATE_LIMIT_SDK_MAX=500
